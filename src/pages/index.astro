---
import Base from '../layouts/Base.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

/* ── Parameter data ── */
const params = [
  {
    name: 'VOICES',
    tag: 'CROWD SIZE',
    range: '1 – 128',
    desc: 'How many distinct singers make up the crowd. More voices thicken the ensemble and intensify the on-screen glow.',
    value: 0.85,
    highlight: true,
  },
  {
    name: 'DEPTH',
    tag: 'VARIATION',
    range: '0 – 100 %',
    desc: 'How far each voice strays from the original in pitch and tone — from a tight unison double to a wildly varied choir.',
    value: 0.55,
  },
  {
    name: 'TIMING',
    tag: 'SPREAD',
    range: '0 – 200 ms',
    desc: 'Spread of micro-timing between voices. Higher values feel looser and more human; lower stays tight and rhythmic.',
    value: 0.35,
  },
  {
    name: 'FORMANT',
    tag: 'CHARACTER',
    range: '0 – 100 %',
    desc: 'Variation in vocal character across the crowd — from near-identical clones to a diverse cast of singers.',
    value: 0.45,
  },
  {
    name: 'STEREO WIDTH',
    tag: 'SPACE',
    range: '0 – 100 %',
    desc: 'Spatial spread of the ensemble, from a mono center point out to the full width of the stereo field.',
    value: 0.75,
  },
  {
    name: 'CHAOS',
    tag: 'MOVEMENT',
    range: '0 – 100 %',
    desc: 'Amount of continuous, organic movement and drift applied to the whole crowd to keep it feeling alive.',
    value: 0.40,
  },
  {
    name: 'DRY / WET',
    tag: 'MIX',
    range: '0 – 100 %',
    desc: 'Wet / dry blend between your source signal and the generated crowd. Pull back to keep the lead up front.',
    value: 0.65,
  },
];

/* ── Feature data ── */
const features = [
  {
    title: 'Up to 128 voices',
    desc: 'Scale from an intimate trio to a stadium-sized chant with a single knob. Every voice is generated, not copied.',
    icon: 'people',
  },
  {
    title: 'Per-voice variation',
    desc: 'Timing, formant and pitch drift independently for each singer, so no two voices ever sit in exactly the same place.',
    icon: 'wave',
  },
  {
    title: 'Living visualizer',
    desc: 'Watch the crowd breathe with your performance — every glowing member reacts to input level in real time.',
    icon: 'eye',
  },
  {
    title: 'True stereo spread',
    desc: 'Place the ensemble anywhere from a dead-center mono huddle to a full-width wall of sound.',
    icon: 'circles',
  },
  {
    title: 'Chaos engine',
    desc: 'Continuous organic movement keeps the crowd human and alive — never robotic, static, or obviously cloned.',
    icon: 'squiggle',
  },
  {
    title: 'Instant, CPU-light',
    desc: 'Musical defaults the moment you load it. Six controls take it anywhere, with latency low enough for tracking.',
    icon: 'bolt',
  },
];

/**
 * Build an SVG arc knob string.
 * value: 0-1, maps onto a 270deg arc starting at 135deg (bottom-left).
 */
function knobArc(value: number, size = 42): string {
  const cx = size / 2;
  const cy = size / 2;
  const r = (size - 6) / 2;
  const startAngle = 135;
  const totalSweep = 270;
  const endAngleFull = startAngle + totalSweep;
  const endAngleValue = startAngle + totalSweep * value;

  function polar(angleDeg: number) {
    const rad = ((angleDeg - 90) * Math.PI) / 180;
    return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };
  }

  function arcPath(from: number, to: number) {
    const s = polar(from);
    const e = polar(to);
    const sweep = to - from;
    const large = sweep > 180 ? 1 : 0;
    return `M ${s.x.toFixed(2)} ${s.y.toFixed(2)} A ${r} ${r} 0 ${large} 1 ${e.x.toFixed(2)} ${e.y.toFixed(2)}`;
  }

  const trackPath = arcPath(startAngle, endAngleFull);
  const valuePath = arcPath(startAngle, endAngleValue);

  return `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="${trackPath}" stroke="rgba(255,255,255,0.1)" stroke-width="3.5" stroke-linecap="round" fill="none"/>
    <path d="${valuePath}" stroke="var(--accent)" stroke-width="3.5" stroke-linecap="round" fill="none"/>
  </svg>`;
}
---

<Base>
  <!-- ════════════════ NAV ════════════════ -->
  <nav class="nav">
    <div class="nav__inner">
      <a href={`${base}`} class="nav__brand">
        <span class="nav__dot"></span>
        <span class="nav__brand-crowd">CROWD</span><span class="nav__brand-control">CONTROL</span>
      </a>

      <div class="nav__right">
        <a href="#features" class="nav__link">Features</a>
        <a href="#parameters" class="nav__link">Parameters</a>
        <span class="nav__version">v1.0</span>
        <a href="#get" class="btn btn--primary btn--sm">Get the plugin</a>
      </div>
    </div>
  </nav>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="hero__text">
        <p class="eyebrow">VOCAL MULTIPLIER &middot; AU / VST3</p>
        <h1 class="hero__h1">One voice becomes <span class="accent-hi">a crowd.</span></h1>
        <p class="hero__sub">
          CrowdControl turns a single take into a living ensemble — gang vocals, festival chants, lush doubles and full choirs — all from one knob. Generated, never copy-pasted.
        </p>
        <div class="hero__ctas">
          <a href="#get" class="btn btn--primary">Download v1.0</a>
          <a href="#parameters" class="btn btn--ghost">See the controls</a>
        </div>
        <div class="hero__stats">
          <div class="stat">
            <span class="stat__val">128</span>
            <span class="stat__label">max voices</span>
          </div>
          <div class="stat">
            <span class="stat__val">7</span>
            <span class="stat__label">controls</span>
          </div>
          <div class="stat">
            <span class="stat__val">&lt;5ms</span>
            <span class="stat__label">latency</span>
          </div>
        </div>
      </div>

      <div class="hero__device">
        <div class="device-frame">
          <img
            src={`${base}plugin-screenshot.png`}
            alt="CrowdControl plugin interface showing 90 voices with chrome hero knob and animated crowd visualization"
            width="600"
            height="500"
            class="device-frame__img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FEATURES ════════════════ -->
  <section class="features" id="features">
    <div class="wrap">
      <p class="eyebrow">WHY CROWDCONTROL</p>
      <h2 class="section-h2">A real crowd, not a stack of copies.</h2>
      <p class="section-sub">
        Every voice is uniquely generated with its own timing, pitch drift and formant character — so the result sounds organic, not phased.
      </p>

      <div class="features__grid">
        {features.map((f) => (
          <div class="fcard">
            <div class="fcard__icon" data-icon={f.icon}>
              {f.icon === 'people' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="7" r="3"/><circle cx="17" cy="7" r="2.5"/>
                  <path d="M2 21v-1a5 5 0 0 1 5-5h4a5 5 0 0 1 5 5v1"/>
                  <path d="M17 10.5a3.5 3.5 0 0 1 3.5 3.5v1"/>
                </svg>
              )}
              {f.icon === 'wave' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 12h2l3-7 4 14 4-10 3 6h4"/>
                </svg>
              )}
              {f.icon === 'eye' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              )}
              {f.icon === 'circles' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="8" cy="12" r="5"/><circle cx="16" cy="12" r="5"/>
                </svg>
              )}
              {f.icon === 'squiggle' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 17c2-4 4 4 6 0s4 4 6 0 4 4 6 0"/>
                </svg>
              )}
              {f.icon === 'bolt' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              )}
            </div>
            <h3 class="fcard__title">{f.title}</h3>
            <p class="fcard__desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════ PARAMETERS ════════════════ -->
  <section class="parameters" id="parameters">
    <div class="wrap">
      <p class="eyebrow">THE CONTROLS</p>
      <h2 class="section-h2">Seven knobs, fully documented.</h2>

      <div class="param-table">
        {params.map((p) => (
          <div class:list={['param-row', { 'param-row--hl': p.highlight }]}>
            <div class="param-row__knob" set:html={knobArc(p.value)} />
            <div class="param-row__name">
              <strong>{p.name}</strong>
              <span class="param-row__tag">{p.tag}</span>
            </div>
            <div class="param-row__range">{p.range}</div>
            <div class="param-row__desc">{p.desc}</div>
          </div>
        ))}
      </div>

      <div class="quality-section">
        <h3 class="quality-title">Quality modes</h3>
        <p class="quality-intro">
          CrowdControl lets you trade CPU for density. Click the mode button in the plugin footer to cycle through three tiers — the setting is fully automatable and saves with your DAW session.
        </p>
        <div class="quality-grid">
          <div class="quality-card">
            <span class="quality-badge quality-badge--eco">ECO</span>
            <span class="quality-voices">16 real voices</span>
            <p>Density taps and diffusion fill out the crowd. Light on CPU — ideal for laptops or sessions with many instances.</p>
          </div>
          <div class="quality-card">
            <span class="quality-badge quality-badge--high">HIGH</span>
            <span class="quality-voices">64 real voices</span>
            <p>Every voice up to 64 gets its own processing chain. A solid middle ground for most sessions.</p>
          </div>
          <div class="quality-card">
            <span class="quality-badge quality-badge--ultra">ULTRA</span>
            <span class="quality-voices">128 real voices</span>
            <p>Full 1:1 processing — every voice on the knob is independently pitch-shifted, time-varied and panned. Maximum density and realism.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ DOWNLOAD CTA ════════════════ -->
  <section class="cta-band" id="get">
    <div class="cta-band__glow" aria-hidden="true"></div>
    <div class="wrap cta-band__inner">
      <h2 class="section-h2">Build your crowd.</h2>
      <p class="section-sub">Free to download on macOS &amp; Windows. AU and VST3.</p>

      <div id="download-area" class="download-area">
        <div class="download-spinner" id="download-spinner">
          <div class="spinner"></div>
          <span>Checking for latest release&hellip;</span>
        </div>
        <div id="download-content" class="download-content" style="display:none;"></div>
        <div id="download-fallback" class="download-fallback" style="display:none;">
          <p>No releases available yet.</p>
          <a href="https://github.com/owenbush/crowdcontrol-releases/releases" class="btn btn--ghost" target="_blank" rel="noopener">
            View GitHub Releases
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FOOTER ════════════════ -->
  <footer class="footer">
    <div class="footer__inner">
      <a href={`${base}`} class="nav__brand">
        <span class="nav__dot"></span>
        <span class="nav__brand-crowd">CROWD</span><span class="nav__brand-control">CONTROL</span>
      </a>
      <div class="footer__links">
        <a href="#features">Features</a>
        <a href="#parameters">Parameters</a>
        <a href="#get">Download</a>
      </div>
      <span class="footer__copy">&copy; 2026 CrowdControl &middot; VOICE &rarr; CROWD</span>
    </div>
  </footer>

  <!-- GitHub Releases fetch -->
  <script>
  async function loadReleases() {
    const spinner = document.getElementById('download-spinner')!;
    const content = document.getElementById('download-content')!;
    const fallback = document.getElementById('download-fallback')!;

    try {
      const res = await fetch(
        'https://api.github.com/repos/owenbush/crowdcontrol-releases/releases/latest',
      );

      if (!res.ok) throw new Error('No release');

      const data = await res.json();
      const version = data.tag_name || data.name || 'unknown';
      const date = data.published_at
        ? new Date(data.published_at).toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'short',
            year: 'numeric',
          })
        : '';

      const assets: { name: string; browser_download_url: string }[] =
        data.assets || [];

      const macVST = assets.find((a: { name: string }) => a.name.includes('macOS-VST3'));
      const macAU = assets.find((a: { name: string }) => a.name.includes('macOS-AU'));
      const winVST = assets.find((a: { name: string }) => a.name.includes('Windows-VST3'));

      if (!macVST && !macAU && !winVST) throw new Error('No matching assets');

      let html = '<div class="download-buttons">';
      if (macVST)
        html += `<a href="${macVST.browser_download_url}" class="btn btn--primary">macOS VST3</a>`;
      if (macAU)
        html += `<a href="${macAU.browser_download_url}" class="btn btn--primary">macOS AU</a>`;
      if (winVST)
        html += `<a href="${winVST.browser_download_url}" class="btn btn--primary">Windows VST3</a>`;
      html += '</div>';
      html += `<p class="download-meta">${version} ${date ? '&middot; ' + date : ''}</p>`;

      content.innerHTML = html;
      spinner.style.display = 'none';
      content.style.display = 'block';
    } catch {
      spinner.style.display = 'none';
      fallback.style.display = 'flex';
    }
  }

  loadReleases();
</script>
</Base>

<!-- ═══════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════ -->
<style>
  /* ── Utilities ── */
  .wrap {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .accent-hi {
    color: var(--accent-hi);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--accent-hi);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .section-h2 {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .section-sub {
    color: var(--text-dim);
    font-size: 17px;
    max-width: 560px;
    line-height: 1.6;
    margin-bottom: 48px;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 15px;
    border-radius: 10px;
    padding: 13px 28px;
    transition: all 0.2s ease;
  }

  .btn--primary {
    background: var(--accent);
    color: #fff;
  }

  .btn--primary:hover {
    background: var(--accent-hi);
    transform: translateY(-1px);
  }

  .btn--ghost {
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: var(--text-dim);
  }

  .btn--ghost:hover {
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff;
  }

  .btn--sm {
    font-size: 13px;
    padding: 9px 20px;
    border-radius: 8px;
  }

  /* ════════════════ NAV ════════════════ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(22, 22, 42, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }

  .nav__inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 60px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    letter-spacing: 1.5px;
  }

  .nav__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
  }

  .nav__brand-crowd {
    font-weight: 700;
    color: #fff;
  }

  .nav__brand-control {
    font-weight: 300;
    color: var(--accent-hi);
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav__link {
    font-size: 14px;
    color: var(--text-dim);
    transition: color 0.15s;
  }

  .nav__link:hover {
    color: #fff;
  }

  .nav__version {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-faint);
  }

  /* ════════════════ HERO ════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    width: 900px;
    height: 620px;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(108, 99, 255, 0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 92px 24px 80px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 48px;
    align-items: center;
  }

  .hero__h1 {
    font-size: clamp(40px, 5.4vw, 66px);
    font-weight: 700;
    line-height: 1.08;
    margin-bottom: 20px;
  }

  .hero__sub {
    font-size: 18px;
    color: var(--text-dim);
    line-height: 1.65;
    max-width: 500px;
    margin-bottom: 32px;
  }

  .hero__ctas {
    display: flex;
    gap: 14px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .hero__stats {
    display: flex;
    gap: 40px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat__val {
    font-family: var(--font-mono);
    font-size: 26px;
    font-weight: 700;
    color: var(--accent-hi);
  }

  .stat__label {
    font-size: 13px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Device frame */
  .hero__device {
    display: flex;
    justify-content: center;
  }

  .device-frame {
    position: relative;
    border-radius: 18px;
    background: linear-gradient(145deg, rgba(45, 45, 68, 0.8), rgba(26, 26, 46, 0.9));
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    padding: 12px;
    max-width: 480px;
    width: 100%;
  }

  .device-frame__img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
  }

  .device-tag {
    position: absolute;
    bottom: -14px;
    right: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 5px 14px;
  }

  /* ════════════════ FEATURES ════════════════ */
  .features {
    padding: 100px 0;
    border-top: 1px solid var(--line);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .fcard {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 32px 28px;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease;
  }

  .fcard:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .fcard__icon {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: rgba(108, 99, 255, 0.14);
    border: 1px solid rgba(108, 99, 255, 0.30);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .fcard__title {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .fcard__desc {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
  }

  /* ════════════════ PARAMETERS ════════════════ */
  .parameters {
    padding: 100px 0;
    border-top: 1px solid var(--line);
  }

  .param-table {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .param-row {
    display: grid;
    grid-template-columns: 54px 1fr 120px 2fr;
    gap: 20px;
    align-items: center;
    padding: 18px 20px;
    border-radius: 12px;
    background: transparent;
    transition: background 0.15s;
  }

  .param-row:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .param-row--hl {
    background: rgba(108, 99, 255, 0.08);
  }

  .param-row--hl:hover {
    background: rgba(108, 99, 255, 0.12);
  }

  .param-row__knob {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .param-row__name {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .param-row__name strong {
    font-size: 15px;
    font-weight: 600;
  }

  .param-row__tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 1px;
  }

  .param-row__range {
    font-family: var(--font-mono);
